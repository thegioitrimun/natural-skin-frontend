│   │   └── auth/
│   │       ├── LoginPage.tsx
│   │       ├── RegisterPage.tsx
│   │       └── AccountPage.tsx
│   └── dashboard/     (Admin — giữ nguyên)
├── components/
│   └── storefront/    ★ MỚI
│       ├── ProductCard.tsx
│       ├── CartDrawer.tsx
│       ├── CategoryCard.tsx
│       ├── HeroBanner.tsx
│       ├── TestimonialCard.tsx
│       └── ...
├── context/
│   ├── CartContext/    ★ MỚI
│   └── EcommerceContext/ (tùy chỉnh)
└── types/
    └── storefront.ts  ★ MỚI
```

